.about-avatar
  position relative
  margin -8rem auto 1rem
  width 10rem
  height 10rem
  z-index 3

  img
    width 100%
    height 100%
    border-radius 50%
    -moz-border-radius 50%
    -webkit-border-radius 50%
    object-fit cover
    -webkit-box-shadow 0 2px 5px 0 rgba(0, 0, 0, 0.16), 0 2px 10px 0 rgba(0, 0, 0, 0.12)
    box-shadow 0 2px 5px 0 rgba(0, 0, 0, 0.16), 0 2px 10px 0 rgba(0, 0, 0, 0.12)

.about-info
  & > div
    margin-bottom .5rem

.about-name
  font-size 1.75rem
  font-weight bold

.about-intro
  font-size 1rem

.about-icons
  & > a:not(:last-child)
    margin-right .5rem

  & > a > i
    font-size 1.5rem

blockquote
  background #f9f9f9
  quotes "\201C""\201D""\2018""\2019"
  border-left .2em solid color-border
  margin 40px 0px
  padding 0px 30px
  line-height line-height
  font-size font-size
  footer
    background color-section
    padding 0
    margin 0
    font-size 90%
    line-height 1em
  cite
    font-style italic
    padding-left 0.5em


